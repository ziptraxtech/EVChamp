# Firebase Admin SDK Credentials (from Firebase Console)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate New Key
# Must be minified JSON on a single line
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@iam.gserviceaccount.com"}

# Neon Database Connection String
# Get from: https://console.neon.tech → Project → Connection Details
# Format: postgresql://user:password@host/db?sslmode=require
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# Admin API Key (for protected endpoints)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your-secure-random-api-key-here

# Clerk Secret Key (from Clerk Dashboard)
CLERK_SECRET_KEY=sk_test_xxxxx

# React App (public keys only - safe to commit as REACT_APP_*)
REACT_APP_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
REACT_APP_API_URL=https://evchamp.in

# Gmail Configuration (for contact emails)
GMAIL_USER=your-email@gmail.com
GMAIL_PASSWORD=your-app-password

# Razorpay Keys (from Razorpay Dashboard)
RAZORPAY_KEY_ID=your-key-id
