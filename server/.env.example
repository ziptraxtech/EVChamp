# ============================================
# 🔐 SERVER BACKEND SECRETS (DO NOT EXPOSE)
# ============================================
# This file is for LOCAL DEVELOPMENT ONLY
# In production, use Vercel/CI-CD environment variables
#
# ⚠️ CRITICAL: NEVER commit the actual .env file to git
# Only commit .env.example with placeholder values
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp server/.env.example server/.env
# 2. Fill in real values (see below)
# 3. server/.env is in .gitignore (won't be committed)
# 4. Backend code will load from server/.env automatically

# ============================================
# 🔑 RAZORPAY BACKEND SECRETS
# ============================================
RAZORPAY_KEY_SECRET=your_live_secret_key_here
RAZORPAY_KEY_ID=your_live_key_id_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# 🔔 FIREBASE PUSH NOTIFICATIONS
# ============================================
# Get from Firebase Console → Project Settings → Service Accounts → Generate New Key
# Paste the entire JSON on ONE line (minified)
# Example: {"type":"service_account","project_id":"evchamp-xxx","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxx@evchamp.iam.gserviceaccount.com",...}
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key_id":"KEY_ID","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"CLIENT_ID","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ============================================
# 🔐 ADMIN API KEY (for notification panel)
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your_secure_random_admin_key_here

# ============================================
# 📦 DATABASE & EXTERNAL SERVICES
# ============================================
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
ZEFLASH_DATABASE_URL=postgresql://user:password@host/db?sslmode=require
CLERK_SECRET_KEY=sk_test_xxxx

# ============================================
# 🔒 ENVIRONMENT & PORT
# ============================================
NODE_ENV=development
PORT=5001

# ============================================
# PRODUCTION SETUP (Vercel)
# ============================================
# Instead of this file, add these to Vercel:
#
# 1. Go to: https://vercel.com/dashboard/project/[project]/settings/environment-variables
# 2. Add each variable above as a new entry
# 3. Set to: "Development, Preview, Production" (all environments)
# 4. Vercel will inject them at build time
#
# For Razorpay specifically:
#   - RAZORPAY_KEY_SECRET
#   - RAZORPAY_KEY_ID
#   - RAZORPAY_WEBHOOK_SECRET
#
# These will be available to server/.env via process.env in production
